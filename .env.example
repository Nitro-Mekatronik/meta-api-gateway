# Production Environment Variables - DO NOT COMMIT TO GIT

# Meta Platform Configuration
META_WEBHOOK_VERIFY_TOKEN=your_prod_verify_token_here
META_APP_SECRET=your_prod_app_secret_here
META_ACCESS_TOKEN=your_prod_access_token_here

# Redis Configuration (Production)
REDIS_HOST=redis.production.internal
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@redis.production.internal:6379

# Database Configuration (Production PostgreSQL)
DATABASE_URL=postgresql://user:password@db.production.internal:5432/nitro_meta_erp
DB_SSL=true

# Nitro ERP Integration
NITRO_ERP_URL=https://erp.nitrobilisim.com
NITRO_ERP_API_KEY=your_prod_erp_api_key_here

# WhatsApp Service
WHATSAPP_SERVICE_URL=https://whatsapp-api.production.internal

# Rate Limiting (Production - stricter)
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=1000
WHATSAPP_RATE_LIMIT_WINDOW_MS=60000
WHATSAPP_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# Security
NODE_ENV=production
LOG_LEVEL=warn
JSON_LIMIT=10mb

# Monitoring
METRICS_ENABLED=true
GRAFANA_URL=https://grafana.production.internal
PROMETHEUS_URL=https://prometheus.production.internal

# Secrets Management (Optional - AWS Secrets Manager)
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ENABLED=false
